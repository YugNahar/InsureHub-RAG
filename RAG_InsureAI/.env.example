# ─────────────────────────────────────────────────────────────────────────────
# InsureHub RAG — environment variables
# Copy this file to .env and fill in the values before running docker compose.
# NEVER commit .env to git — it contains secrets.
# ─────────────────────────────────────────────────────────────────────────────


# ── LLM backend (vLLM) ───────────────────────────────────────────────────────
# URL of your vLLM server (no trailing slash).
# Example: http://your-server-ip:8000
VLLM_HOST=http://your-vllm-host:8000

# Model name as registered in vLLM (must match --served-model-name).
# Example: Qwen/Qwen2.5-7B-Instruct
VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# API key for vLLM (leave blank if your server has no auth).
VLLM_API_KEY=

# Max tokens the LLM generates per response.
VLLM_MAX_TOKENS=1024


# ── Admin credentials ────────────────────────────────────────────────────────
# Username shown on the admin login page.
ADMIN_USERNAME=admin

# Password for the admin panel.
ADMIN_PASSWORD=change-me

# Password for the super-admin panel (can delete agents across all views).
SUPER_ADMIN_PASSWORD=change-me-super

# Password human agents use to log into the agent dashboard.
# If not set, falls back to ADMIN_PASSWORD.
AGENT_PASSWORD=change-me-agent

# TEMPORARY: admin/agent login is currently OFF BY DEFAULT (unset = disabled)
# so the app works with zero .env setup during early testing. Anyone who can
# reach the server can upload/delete documents and clear the cache with no
# password. Set this to false explicitly before real users can reach this
# deployment.
DISABLE_AUTH=true


# ── Auth / JWT ───────────────────────────────────────────────────────────────
# Secret used to sign JWT tokens — generate a strong random string.
# Example: openssl rand -hex 32
AUTH_SECRET_KEY=change-me-use-a-long-random-string

# How long login sessions last (minutes). Default: 480 (8 hours).
AUTH_TOKEN_EXPIRE_MINUTES=480


# ── Email / agent handoff ────────────────────────────────────────────────────
# Gmail address that sends handoff notification emails.
GMAIL_SENDER=your-gmail@gmail.com

# Gmail App Password (NOT your account password).
# Generate one at: https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Email address of the default agent who receives handoff notifications.
AGENT_EMAIL=agent@example.com


# ── Embedding model ──────────────────────────────────────────────────────────
# Sentence-transformer model used for vector embeddings and semantic search.
# Change only if you want a different embedding model (requires re-ingesting all docs).
EMBED_MODEL=BAAI/bge-base-en-v1.5


# ── Vector store collection names ────────────────────────────────────────────
# Chroma collection names — only change if you need multiple isolated deployments.
TVEC_DOCS_COLLECTION=insurance_docs
TVEC_SUMMARIES_COLLECTION=insurance_summaries
TVEC_VIDEOS_COLLECTION=insurance_videos
TVEC_WEBPAGES_COLLECTION=insurance_webpages


# ── KV answer cache ──────────────────────────────────────────────────────────
# How long cached answers are valid (seconds). Default: 3600 (1 hour).
KV_CACHE_TTL=3600

# Maximum number of cached entries before LRU eviction kicks in.
KV_CACHE_MAX_ENTRIES=500

# Cosine similarity threshold for semantic cache hits (0–1). Default: 0.92.
SEMANTIC_CACHE_THRESHOLD=0.92


# ── Retrieval tuning ─────────────────────────────────────────────────────────
# BGE reranker score gate — queries whose best chunk scores below this are
# refused without calling the LLM. Scores are sigmoid-bounded probabilities
# in [0,1] (unrelated content ≈ 0.0000, marginally-topical ≈ 0.01-0.16,
# genuinely relevant ≈ 0.3+, near-certain ≈ 0.9+). Default: 0.2.
RERANK_GATE_THRESHOLD=0.2


# ── Optional: alternative LLM backends ──────────────────────────────────────
# Uncomment and fill in if you want to use OpenAI or Anthropic instead of vLLM.
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
